# ===========================================
# Boilerplate Environment Configuration
# ===========================================

# Database Connection
# Start with: docker compose up -d
# Uses port 5433 to avoid conflicts with other projects
DATABASE_URI=postgres://postgres:postgres@localhost:5433/payload

# Payload CMS Secret (minimum 32 characters)
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE_MIN_32_CHARS

# Public URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Site Name (used in SEO titles)
NEXT_PUBLIC_SITE_NAME=My Website

# ===========================================
# Optional Configuration
# ===========================================

# Draft Preview Authentication
# Generate with: openssl rand -hex 16
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# Cron Job Authentication (if needed)
# CRON_SECRET=YOUR_CRON_SECRET_HERE

# ===========================================
# External Content API (for AI agents)
# ===========================================
# Static bearer token for external API access
# Generate with: openssl rand -hex 32
# EXTERNAL_API_TOKEN=your-token-here

# ===========================================
# Newsletter Integration (Optional)
# ===========================================
# Brevo (Sendinblue) configuration
# BREVO_API_KEY=xkeysib-your-api-key
# BREVO_LIST_ID=your-list-id
# BREVO_DOI_TEMPLATE_ID=your-template-id
# BREVO_COURSE_ACCESS_TEMPLATE_ID=
# NEXT_PUBLIC_COURSES_URL=https://courses.devince.dev

# ===========================================
# Stripe (Course Purchases)
# ===========================================
# Secret API key (Dashboard → Developers → API keys)
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (Dashboard → Developers → Webhooks, or `stripe listen`)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price id used for the (future) hosted Checkout flow
# STRIPE_PRICE_ID=price_...

# ===========================================
# Apps subdomain (apps.devince.dev)
# ===========================================
# HMAC secret for signed download tokens (generate: openssl rand -hex 32)
# DOWNLOAD_TOKEN_SECRET=
# Public URL of the apps subdomain
# NEXT_PUBLIC_APPS_URL=https://apps.devince.dev
# Brevo transactional email template for download links
# BREVO_DOWNLOAD_TEMPLATE_ID=
