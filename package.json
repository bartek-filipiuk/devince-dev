{
  "name": "",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "check:security": "bash scripts/check-security.sh",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3010",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.86.0",
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/live-preview-react": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-form-builder": "3.86.0",
    "@payloadcms/plugin-nested-docs": "3.86.0",
    "@payloadcms/plugin-redirects": "3.86.0",
    "@payloadcms/plugin-search": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@shikijs/transformers": "^4.3.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "16.4.7",
    "drizzle-kit": "^0.31.10",
    "geist": "^1.7.2",
    "graphql": "^16.8.2",
    "lucide-react": "^0.378.0",
    "next": "15.4.11",
    "next-sitemap": "^4.2.3",
    "payload": "3.86.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "0.35.3",
    "shiki": "^4.3.1",
    "stripe": "^22.3.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/unist": "^3.0.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.5.2",
    "copyfiles": "^2.4.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.7",
    "jsdom": "29.1.1",
    "pg": "^8.22.0",
    "playwright": "1.61.1",
    "playwright-core": "1.61.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
